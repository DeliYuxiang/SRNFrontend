{
  "name": "srn-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "format:check": "prettier --check 'src/**/*.{ts,vue}'",
    "format:fix": "prettier --write 'src/**/*.{ts,vue}'",
    "generate:api": "openapi-typescript https://srn-worker.delibill.workers.dev/doc -o src/types/srn-api.d.ts"
  },
  "dependencies": {
    "openapi-fetch": "^0.17.0",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.0",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.3.3",
    "typescript": "^5.7.0",
    "vite": "^6.3.0",
    "vue-tsc": "^2.2.0"
  }
}
