# Backend API base URL.
#
# Leave EMPTY (default) for:
#   - Local dev:           Vite proxy in vite.config.ts handles /v1/*
#   - Cloudflare Pages:    public/_redirects handles /v1/*
#
# Set to a full URL for platforms without server-side proxy (e.g. GitHub Pages):
#   VITE_API_BASE=https://srn.majiyabakunai.moe
#
VITE_API_BASE=
